# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://devotional:devotional@localhost:5432/devotional_journal

# Redis
REDIS_URL=redis://localhost:6379/0

# Encryption
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Never change this after data has been written — all encrypted entries will be unreadable.
ENCRYPTION_ROOT_KEY=your-32-character-encryption-key

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@devotionaljournal.app

# Magic Link
MAGIC_LINK_EXPIRY_MINUTES=15
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://devotionaljournal.net/api/auth/google/callback/

# LLM
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Production LLM (uncomment for prod)
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=your-api-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307
