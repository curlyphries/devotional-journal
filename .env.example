# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-at-least-50-characters-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=devotional
POSTGRES_USER=devotional
POSTGRES_PASSWORD=devotional_dev
DATABASE_URL=postgres://devotional:devotional_dev@db:5432/devotional

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_ROOT_KEY=your-32-character-encryption-key-here

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# LLM_BACKEND=openai
# OPENAI_API_KEY=your-openai-api-key
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_BACKEND=openai

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourapp.example.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback/

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
VITE_API_URL=http://localhost:8001/api/v1
