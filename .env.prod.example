# ─── Production Environment Template ─────────────────────────────────────────
# Copy to .env.prod and fill in all values before deploying.
# Generate SECRET_KEY:       python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# Generate ENCRYPTION_ROOT_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(32)[:32])"
# WARNING: Never change ENCRYPTION_ROOT_KEY after data has been written.

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-output-of-secrets.token_urlsafe-50
DEBUG=False
ALLOWED_HOSTS=curlyphries.net,www.curlyphries.net

# ─── Reverse-proxy / sub-path ─────────────────────────────────────────────────
# Set FORCE_SCRIPT_NAME if Django runs under a URL sub-path (e.g. /devotional-journal).
# This ensures redirects generated by Django include the prefix.
FORCE_SCRIPT_NAME=/devotional-journal
# Set to false when a reverse proxy (Nginx) handles SSL termination.
# Without this, Django will issue SSL redirect loops on HTTP-only internal traffic.
SECURE_SSL_REDIRECT=false

# ─── Database (host Postgres, reached via host.docker.internal) ───────────────
# NOTE: Before first deploy you must:
#   1. sudo -u postgres psql -c "CREATE USER devotional_user WITH PASSWORD '...';"
#   2. sudo -u postgres psql -c "CREATE DATABASE devotional OWNER devotional_user;"
#   3. Add to /etc/postgresql/16/main/pg_hba.conf:
#        host  devotional  devotional_user  172.16.0.0/12  md5
#   4. Set listen_addresses = '*' in postgresql.conf (or at least the Docker bridge IP)
#   5. sudo ufw allow from 172.16.0.0/12 to any port 5432
#   6. sudo systemctl restart postgresql
DATABASE_URL=postgres://devotional_user:your-db-password@host.docker.internal:5432/devotional
POSTGRES_DB=devotional
POSTGRES_USER=devotional_user
POSTGRES_PASSWORD=your-db-password

# ─── Redis (host Redis, reached via host.docker.internal) ────────────────────
# NOTE: Redis must be listening on 0.0.0.0 or the Docker bridge IP.
#   sudo ufw allow from 172.16.0.0/12 to any port 6379  (if using UFW)
REDIS_URL=redis://host.docker.internal:6379/1
CELERY_BROKER_URL=redis://host.docker.internal:6379/1
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/1

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_ROOT_KEY=replace-with-32-char-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list — no trailing comma, no empty entries (causes system check failure).
CORS_ALLOWED_ORIGINS=https://curlyphries.net,https://www.curlyphries.net

# ─── LLM ──────────────────────────────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_BACKEND=openai

# ─── Email ────────────────────────────────────────────────────────────────────
# Set to a real SMTP backend for production magic-link emails.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@curlyphries.net

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Authorised redirect URI must be registered in Google Cloud Console as:
#   https://curlyphries.net/devotional-journal/api/v1/auth/google/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://curlyphries.net/devotional-journal/api/v1/auth/google/callback/

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://curlyphries.net/devotional-journal
VITE_API_URL=/devotional-journal/api/v1

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
